[Unit]
Description=RMBC CCTV Witness Statement Generator
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/CCTV_Statement
Environment="ANTHROPIC_API_KEY=PUT_YOUR_KEY_HERE"
ExecStart=/usr/bin/python3 /root/CCTV_Statement/cctv_app.py
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
